---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import UspCards from '../components/UspCards.astro';
import Services from '../components/Services.astro';
import AboutSection from '../components/AboutSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CounterSection from '../components/CounterSection.astro';
import Reviews from '../components/Reviews.astro';
import CtaSection from '../components/CtaSection.astro';
import ContactSection from '../components/ContactSection.astro';

const title = 'Kfz Service Beyer · Werkstatt München-Gern (U-Bahn U1)';
const description =
  'Inhabergeführte Kfz-Werkstatt im Stadtteil Gern, München. Direkt an der U-Bahn-Haltestelle Gern (U1). HU/AU, Inspektion, Reparatur, Klima, Reifen. 4,8 ★ Google. Termine telefonisch oder per E-Mail.';
---

<Layout title={title} description={description}>
  <Hero />
  <UspCards />
  <Services />
  <AboutSection />
  <HowItWorks />
  <CounterSection />
  <Reviews />
  <ContactSection />
  <CtaSection />
</Layout>
