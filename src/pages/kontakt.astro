---
import Layout from '../layouts/Layout.astro';
import { business } from '../data/business';

const title = 'Kontakt · Kfz Service Beyer München - Termin anfragen';
const description =
  'Termin anfragen oder Anfahrt zur Kfz-Werkstatt Beyer in München. Waisenhausstraße 44, fußläufig zur U-Bahn. Telefon ' + business.phoneDisplay + '.';

// Formspree-Endpoint - vor Live-Schalten ersetzen.
const formAction = '[FORMSPREE_URL]';
const mapEmbed = `https://maps.google.com/maps?q=${encodeURIComponent(business.street + ', ' + business.zip + ' ' + business.city)}&t=&z=16&ie=UTF8&iwloc=&output=embed`;
---

<Layout title={title} description={description}>
  <!-- Page Header (Full-Bleed) -->
  <section class="relative -mt-16 md:-mt-20 min-h-[480px] md:min-h-[560px] flex items-end text-white overflow-hidden">
    <img
      src="https://images.pexels.com/photos/4489732/pexels-photo-4489732.jpeg?auto=compress&cs=tinysrgb&w=1920"
      alt="Kfz-Werkstatt mit Auto auf der Hebebühne"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="1280"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-dark)]/85 via-[var(--color-dark)]/65 to-[var(--color-dark)]/30"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-dark)]/40 to-transparent"></div>

    <div class="container-x relative z-10 pt-28 md:pt-32 pb-12 md:pb-16 w-full">
      <div class="max-w-3xl">
        <nav aria-label="Breadcrumb" class="text-sm text-white/70 mb-4">
          <ol class="flex items-center gap-2">
            <li><a href="/" class="hover:text-[var(--color-accent)] transition-colors">Start</a></li>
            <li aria-hidden="true">›</li>
            <li class="text-white font-medium" aria-current="page">Kontakt</li>
          </ol>
        </nav>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-5 text-white">
          Termin? Schnellster Weg ist ein Anruf.
        </h1>
        <p class="text-lg md:text-xl text-white/85 leading-relaxed mb-8">
          Rufen Sie uns einfach an - wir besprechen Ihr Anliegen und finden direkt einen Termin. Lieber schreiben? Nutzen Sie das Formular unten, wir melden uns spätestens am nächsten Werktag zurück.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href={business.phoneHref} class="btn btn-accent text-lg px-6 py-4 font-num">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
            </svg>
            {business.phoneDisplay}
          </a>
          <a href={`mailto:${business.email}`} class="btn btn-ghost-light text-lg px-6 py-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
            E-Mail schreiben
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hauptbereich: Formular + Adresse + Map -->
  <section class="py-14 md:py-20 bg-[var(--color-bg)]">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12">
        <!-- Formular -->
        <div class="lg:col-span-7">
          <div class="bg-[var(--color-bg-alt)] rounded-3xl p-7 md:p-10 border border-[var(--color-border)]">
            <h2 class="text-2xl md:text-3xl font-bold mb-2">Termin per Formular anfragen</h2>
            <p class="text-[var(--color-text-muted)] mb-7">
              Ein paar Angaben - wir rufen Sie zurück. Pflichtfelder sind mit * markiert.
            </p>

            <form
              action={formAction}
              method="POST"
              class="space-y-5"
              data-contact-form
              novalidate
            >
              <!-- Honeypot Spam-Schutz -->
              <div aria-hidden="true" style="position:absolute; left:-10000px; top:auto; width:1px; height:1px; overflow:hidden;">
                <label>Bitte nicht ausfüllen <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" /></label>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="name" class="block text-sm font-semibold mb-1.5">Name *</label>
                  <input
                    id="name" name="name" type="text" required autocomplete="name"
                    class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-base focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent-soft)]"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold mb-1.5">Telefon *</label>
                  <input
                    id="phone" name="phone" type="tel" required autocomplete="tel" inputmode="tel"
                    class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-base focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent-soft)]"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label for="email" class="block text-sm font-semibold mb-1.5">E-Mail</label>
                  <input
                    id="email" name="email" type="email" autocomplete="email"
                    class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-base focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent-soft)]"
                  />
                </div>
                <div>
                  <label for="plate" class="block text-sm font-semibold mb-1.5">Kennzeichen</label>
                  <input
                    id="plate" name="plate" type="text" placeholder="z. B. M-AB 1234"
                    class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-base focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent-soft)]"
                  />
                </div>
              </div>

              <div>
                <label for="topic" class="block text-sm font-semibold mb-1.5">Anliegen *</label>
                <select
                  id="topic" name="topic" required
                  class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-base focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent-soft)]"
                >
                  <option value="">Bitte wählen …</option>
                  <option>HU / AU - Hauptuntersuchung</option>
                  <option>Inspektion / Wartung</option>
                  <option>Reparatur</option>
                  <option>Bremsen-Service</option>
                  <option>Reifenwechsel / -einlagerung</option>
                  <option>Klimaanlagen-Service</option>
                  <option>Diagnose / Fehlersuche</option>
                  <option>Ölwechsel</option>
                  <option>Achsvermessung</option>
                  <option>Sonstiges</option>
                </select>
              </div>

              <div>
                <label for="appointment" class="block text-sm font-semibold mb-1.5">Wunschtermin</label>
                <input
                  id="appointment" name="appointment" type="text" placeholder="z. B. nächste Woche vormittags"
                  class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-base focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent-soft)]"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-semibold mb-1.5">Beschreibung *</label>
                <textarea
                  id="message" name="message" rows="5" required
                  placeholder="Was sollen wir uns ansehen? Symptome, Zeitpunkt, Besonderheiten …"
                  class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-base focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent-soft)]"
                ></textarea>
              </div>

              <div class="flex items-start gap-3">
                <input
                  id="privacy" name="privacy" type="checkbox" required
                  class="mt-1 w-4 h-4 rounded border-[var(--color-border)] text-[var(--color-accent)] focus:ring-[var(--color-accent)]"
                />
                <label for="privacy" class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                  Ich habe die <a href="/datenschutz/" class="text-[var(--color-accent)] underline underline-offset-2 hover:text-[var(--color-accent-hover)]">Datenschutzerklärung</a> gelesen und stimme zu, dass meine Angaben zur Bearbeitung meiner Anfrage verwendet werden. *
                </label>
              </div>

              <button
                type="submit"
                class="btn btn-accent w-full text-lg py-4"
              >
                Anfrage senden
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7"/>
                </svg>
              </button>

              <div data-form-success class="hidden bg-[#E6F5E9] border border-[#9DD3A8] text-[#1F6B36] rounded-xl p-4 text-sm">
                Danke für Ihre Anfrage! Wir melden uns spätestens am nächsten Werktag bei Ihnen zurück.
              </div>
            </form>
          </div>
        </div>

        <!-- Adresse & Öffnungszeiten -->
        <aside class="lg:col-span-5 space-y-6">
          <div class="bg-[var(--color-bg-alt)] rounded-2xl p-7 border border-[var(--color-border)]">
            <h2 class="text-xl font-bold mb-5">Adresse & Anfahrt</h2>
            <div class="space-y-5">
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5 text-[var(--color-accent)]" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <div>
                  <div class="font-semibold text-[var(--color-text)]">{business.street}</div>
                  <div class="text-[var(--color-text-muted)]">{business.zip} {business.city}</div>
                  <div class="text-sm text-[var(--color-text-muted)] mt-1">{business.district}</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5 text-[var(--color-accent)]" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
                <div>
                  <a href={business.phoneHref} class="text-xl font-bold text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] font-num">{business.phoneDisplay}</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5 text-[var(--color-accent)]" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
                <div>
                  <a href={`mailto:${business.email}`} class="text-[var(--color-text)] hover:text-[var(--color-accent)] break-all">{business.email}</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5 text-[var(--color-accent)]" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 010 18M12 3a14 14 0 000 18"/></svg>
                <div class="text-[var(--color-text-muted)] leading-relaxed">{business.transit}</div>
              </div>
            </div>
            <a
              href={business.mapsLink}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline w-full mt-6 justify-center"
            >
              Route auf Google Maps
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
            </a>
          </div>

          <div class="bg-[var(--color-bg-alt)] rounded-2xl p-7 border border-[var(--color-border)]">
            <h2 class="text-xl font-bold mb-5">Öffnungszeiten</h2>
            <table class="w-full text-base">
              <tbody>
                {business.hours.map((h) => {
                  const isClosed = h.t === 'Geschlossen';
                  return (
                    <tr class="border-b border-[var(--color-border)] last:border-0">
                      <td class="py-2.5 font-medium">{h.d}</td>
                      <td class:list={["py-2.5 text-right font-num", isClosed ? "text-[var(--color-text-muted)]" : "text-[var(--color-text)] font-semibold"]}>{h.t}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
            <p class="text-sm text-[var(--color-text-muted)] mt-5 leading-relaxed">
              Außerhalb der Öffnungszeiten erreichen Sie uns am besten per E-Mail oder über das Formular.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="bg-[var(--color-bg-alt)]">
    <div class="rounded-none overflow-hidden h-[420px] md:h-[500px] border-y border-[var(--color-border)]">
      <iframe
        src={mapEmbed}
        width="100%"
        height="100%"
        style="border:0;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Karte: ${business.name}, ${business.street}`}
      ></iframe>
    </div>
  </section>
</Layout>

<script is:inline>
  // Wenn der Formspree-Endpoint nicht gesetzt ist, fallen wir auf mailto:-Versand zurück.
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('[data-contact-form]');
    if (!form) return;
    const action = form.getAttribute('action') || '';
    if (action.startsWith('[FORMSPREE_URL') || action === '') {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const data = new FormData(form);
        if (data.get('_gotcha')) return; // Honeypot
        const subject = encodeURIComponent('Werkstatt-Anfrage von ' + (data.get('name') || ''));
        const lines = [
          'Name: ' + (data.get('name') || ''),
          'Telefon: ' + (data.get('phone') || ''),
          'E-Mail: ' + (data.get('email') || ''),
          'Kennzeichen: ' + (data.get('plate') || ''),
          'Anliegen: ' + (data.get('topic') || ''),
          'Wunschtermin: ' + (data.get('appointment') || ''),
          '',
          'Beschreibung:',
          (data.get('message') || ''),
        ];
        const body = encodeURIComponent(lines.join('\n'));
        window.location.href = 'mailto:info@kfz-service-beyer.de?subject=' + subject + '&body=' + body;
        const ok = form.querySelector('[data-form-success]');
        if (ok) ok.classList.remove('hidden');
      });
    }
  });
</script>
