---
import Layout from '../layouts/Layout.astro';
import { business } from '../data/business';

const title = 'Kontakt · Kfz Service Beyer München-Gern - Termin per Telefon oder E-Mail';
const description =
  'Termin vereinbaren bei Kfz Service Beyer im Stadtteil Gern, München. Direkt an der U-Bahn-Haltestelle Gern (U1). Telefonisch unter ' + business.phoneDisplay + ' oder per E-Mail.';

const mapEmbed = `https://maps.google.com/maps?q=${encodeURIComponent(business.street + ', ' + business.zip + ' ' + business.city)}&t=&z=16&ie=UTF8&iwloc=&output=embed`;
---

<Layout title={title} description={description}>
  <!-- Page Header (Full-Bleed) -->
  <section class="relative -mt-16 md:-mt-20 min-h-[480px] md:min-h-[560px] flex items-end text-white overflow-hidden">
    <img
      src="https://images.pexels.com/photos/4489732/pexels-photo-4489732.jpeg?auto=compress&cs=tinysrgb&w=1920"
      alt="Kfz-Werkstatt mit Auto auf der Hebebühne"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="1280"
    />
    <div class="absolute inset-0 hero-overlay"></div>

    <div class="container-x relative z-10 pt-28 md:pt-32 pb-12 md:pb-16 w-full">
      <div class="max-w-3xl">
        <nav aria-label="Breadcrumb" class="text-sm text-white/80 mb-4 hero-text-shadow">
          <ol class="flex items-center gap-2">
            <li><a href="/" class="hover:text-[var(--color-accent)] transition-colors">Start</a></li>
            <li aria-hidden="true">›</li>
            <li class="text-white font-medium" aria-current="page">Kontakt</li>
          </ol>
        </nav>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-5 text-white hero-text-shadow">
          Termin? Anrufen oder schreiben.
        </h1>
        <p class="text-lg md:text-xl text-white/90 leading-relaxed mb-8 hero-text-shadow">
          Wir arbeiten ausschließlich nach Termin. Vereinbaren Sie Ihren Termin bequem telefonisch oder per E-Mail - wir melden uns spätestens am nächsten Werktag bei Ihnen zurück.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href={business.phoneHref} class="btn btn-accent text-lg px-6 py-4 font-num">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
            </svg>
            {business.phoneDisplay}
          </a>
          <a href={`mailto:${business.email}`} class="btn btn-ghost-light text-lg px-6 py-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
            E-Mail schreiben
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hauptbereich: Telefon/E-Mail-Cards + Sidebar -->
  <section class="py-14 md:py-20 bg-[var(--color-bg)]">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12">
        <!-- Telefon + E-Mail Cards -->
        <div class="lg:col-span-7 space-y-6">
          <div class="max-w-2xl mb-2">
            <span class="text-sm font-semibold text-[var(--color-accent)] uppercase tracking-wider">So erreichen Sie uns</span>
            <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4 leading-tight">Anruf oder E-Mail - Sie wählen.</h2>
            <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
              Termine vereinbaren wir ausschließlich telefonisch oder per E-Mail. So sind wir sicher, dass Sie ohne Wartezeit drankommen.
            </p>
          </div>

          <!-- Telefon Card -->
          <a
            href={business.phoneHref}
            class="group block bg-[var(--color-bg-alt)] rounded-2xl p-6 md:p-8 border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:shadow-lg transition-all"
          >
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 rounded-2xl bg-[var(--color-accent)] flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
                </svg>
              </div>
              <div class="flex-1">
                <div class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-1">Telefon</div>
                <div class="text-3xl md:text-4xl font-bold text-[var(--color-accent)] font-num mb-2">{business.phoneDisplay}</div>
                <p class="text-[var(--color-text-muted)] leading-relaxed">
                  Persönlich erreichbar Mo - Do von 7 bis 17 Uhr, Fr bis 12 Uhr. Außerhalb dieser Zeiten am besten per E-Mail.
                </p>
              </div>
            </div>
          </a>

          <!-- E-Mail Card -->
          <a
            href={`mailto:${business.email}`}
            class="group block bg-[var(--color-bg-alt)] rounded-2xl p-6 md:p-8 border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:shadow-lg transition-all"
          >
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 rounded-2xl bg-[var(--color-dark)] flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="M2 7l10 7 10-7"/>
                </svg>
              </div>
              <div class="flex-1">
                <div class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-1">E-Mail</div>
                <div class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-2 break-all">{business.email}</div>
                <p class="text-[var(--color-text-muted)] leading-relaxed">
                  Schreiben Sie uns Ihr Anliegen, gerne mit Kennzeichen und Wunschtermin. Wir melden uns spätestens am nächsten Werktag zurück.
                </p>
              </div>
            </div>
          </a>
        </div>

        <!-- Sidebar: Adresse + Öffnungszeiten -->
        <aside class="lg:col-span-5 space-y-6">
          <div class="bg-[var(--color-bg-alt)] rounded-2xl p-7 border border-[var(--color-border)]">
            <h2 class="text-xl font-bold mb-5">Adresse & Anfahrt</h2>
            <div class="space-y-5">
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5 text-[var(--color-accent)]" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <div>
                  <div class="font-semibold text-[var(--color-text)]">{business.street}</div>
                  <div class="text-[var(--color-text-muted)]">{business.zip} {business.city}</div>
                  <div class="text-sm text-[var(--color-text-muted)] mt-1">Stadtteil Gern</div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <svg class="flex-shrink-0 mt-0.5 text-[var(--color-accent)]" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 010 18M12 3a14 14 0 000 18"/></svg>
                <div class="text-[var(--color-text-muted)] leading-relaxed">{business.transit}</div>
              </div>
            </div>
            <a
              href={business.mapsLink}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline w-full mt-6 justify-center"
            >
              Route auf Google Maps
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
            </a>
          </div>

          <div class="bg-[var(--color-bg-alt)] rounded-2xl p-7 border border-[var(--color-border)]">
            <h2 class="text-xl font-bold mb-5">Öffnungszeiten</h2>
            <table class="w-full text-base">
              <tbody>
                {business.hours.map((h) => {
                  const isClosed = h.t === 'Geschlossen';
                  return (
                    <tr class="border-b border-[var(--color-border)] last:border-0">
                      <td class="py-2.5 font-medium">{h.d}</td>
                      <td class:list={["py-2.5 text-right font-num", isClosed ? "text-[var(--color-text-muted)]" : "text-[var(--color-text)] font-semibold"]}>{h.t}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
            <p class="text-sm text-[var(--color-text-muted)] mt-5 leading-relaxed">
              Außerhalb der Öffnungszeiten erreichen Sie uns am besten per E-Mail.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Map mit U-Bahn-Hervorhebung daneben -->
  <section class="bg-[var(--color-bg-alt)] py-14 md:py-20">
    <div class="container-x">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10">
        <!-- U-Bahn-Hinweis links -->
        <div class="lg:col-span-4 flex flex-col justify-center">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-accent-soft)] text-[var(--color-accent-hover)] text-sm font-semibold mb-4 self-start">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="3" width="14" height="14" rx="3"/><path d="M5 11h14"/><circle cx="9" cy="14" r="1" fill="currentColor"/><circle cx="15" cy="14" r="1" fill="currentColor"/><path d="M8 17l-2 4M16 17l2 4"/></svg>
            ÖPNV-Anbindung
          </div>
          <h2 class="text-3xl md:text-4xl font-bold leading-tight mb-4">
            Direkt an der<br/><span class="text-[var(--color-accent)]">U-Bahn Gern (U1).</span>
          </h2>
          <p class="text-lg text-[var(--color-text-muted)] leading-relaxed mb-5">
            Im Stadtteil Gern, fußläufig zur U-Bahn-Haltestelle Gern (Linie U1). So können Sie Ihren Wagen morgens abgeben und ohne Umwege weiter zur Arbeit fahren.
          </p>
          <ul class="space-y-2.5 mb-2">
            <li class="flex items-start gap-2.5 text-[var(--color-text)]">
              <svg class="mt-1 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F39239" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5 9-11"/></svg>
              <span>U-Bahn Gern (U1) - direkt vor der Tür</span>
            </li>
            <li class="flex items-start gap-2.5 text-[var(--color-text)]">
              <svg class="mt-1 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F39239" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5 9-11"/></svg>
              <span>Parkplätze unmittelbar vor der Werkstatt</span>
            </li>
            <li class="flex items-start gap-2.5 text-[var(--color-text)]">
              <svg class="mt-1 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F39239" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5 9-11"/></svg>
              <span>Stadtteil Gern - nördlich der Innenstadt</span>
            </li>
          </ul>
        </div>

        <!-- Map rechts -->
        <div class="lg:col-span-8">
          <div class="rounded-2xl overflow-hidden h-[420px] md:h-[500px] border border-[var(--color-border)] shadow-sm bg-white">
            <iframe
              src={mapEmbed}
              width="100%"
              height="100%"
              style="border:0;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Karte: ${business.name}, ${business.street}`}
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
