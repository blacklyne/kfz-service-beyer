---
import Layout from '../layouts/Layout.astro';
import CtaSection from '../components/CtaSection.astro';
import { services, business } from '../data/business';

const title = 'Leistungen · Kfz Service Beyer München - TÜV, Inspektion, Reparatur';
const description =
  'Alle Leistungen Ihrer Kfz-Werkstatt in München: HU/AU, Inspektion, Bremsen, Reifen, Klimaanlage, Diagnose, Ölwechsel und mehr. Faire Preise, persönliche Beratung.';

const iconPath: Record<string, string> = {
  wrench: 'M14 7l3-3m0 0l3 3m-3-3v9.5a3.5 3.5 0 11-7 0V12m0 0L4 18m6-6l4 4',
  car: 'M5 17h14M5 17v3m14-3v3M3 13l2-6h14l2 6m-18 0v4h18v-4M3 13h18M7 16.5h.01M17 16.5h.01',
  disc: 'M12 12m-9 0a9 9 0 1018 0 9 9 0 10-18 0M12 12m-3.5 0a3.5 3.5 0 107 0 3.5 3.5 0 10-7 0',
  target: 'M12 12m-9 0a9 9 0 1018 0 9 9 0 10-18 0M12 12m-5 0a5 5 0 1010 0 5 5 0 10-10 0M12 12h.01',
  shield: 'M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z M9 12l2 2 4-4',
  droplet: 'M12 3l5.5 8a6.5 6.5 0 11-11 0L12 3z',
  snowflake: 'M12 3v18M5 7l14 10M5 17l14-10M3 12h18M9 5l3-2 3 2M9 19l3 2 3-2',
  cpu: 'M9 3h6v3h3v3h3v6h-3v3h-3v3H9v-3H6v-3H3V9h3V6h3z M9 9h6v6H9z',
  circle: 'M12 12m-9 0a9 9 0 1018 0 9 9 0 10-18 0M12 12m-5 0a5 5 0 1010 0 5 5 0 10-10 0',
};

// Services-Schema-JSON-LD: ItemList aller Leistungen
const servicesSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Leistungen Kfz Service Beyer München',
  itemListElement: services.map((s, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    item: {
      '@type': 'Service',
      name: s.title,
      description: s.description,
      provider: {
        '@type': 'AutoRepair',
        name: business.name,
        '@id': new URL('/#business', Astro.site).toString(),
      },
    },
  })),
};
---

<Layout title={title} description={description}>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(servicesSchema)} />

  <!-- Page Header (Full-Bleed) -->
  <section class="relative -mt-16 md:-mt-20 min-h-[440px] md:min-h-[520px] flex items-end text-white overflow-hidden">
    <img
      src="https://images.pexels.com/photos/3807329/pexels-photo-3807329.jpeg?auto=compress&cs=tinysrgb&w=1920"
      alt="Werkzeug und Auto in der Kfz-Werkstatt"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="1280"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-dark)]/85 via-[var(--color-dark)]/65 to-[var(--color-dark)]/30"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-dark)]/40 to-transparent"></div>

    <div class="container-x relative z-10 pt-28 md:pt-32 pb-12 md:pb-16 w-full">
      <div class="max-w-3xl">
        <nav aria-label="Breadcrumb" class="text-sm text-white/70 mb-4">
          <ol class="flex items-center gap-2">
            <li><a href="/" class="hover:text-[var(--color-accent)] transition-colors">Start</a></li>
            <li aria-hidden="true">›</li>
            <li class="text-white font-medium" aria-current="page">Leistungen</li>
          </ol>
        </nav>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-5 text-white">
          Unsere Leistungen - alles für Ihr Auto.
        </h1>
        <p class="text-lg md:text-xl text-white/85 leading-relaxed">
          Vom Ölwechsel bis zur Hauptuntersuchung. Wir betreuen alle gängigen Marken und Modelle - mit ehrlicher Beratung, fairen Preisen und transparenten Kostenvoranschlägen.
        </p>
      </div>
    </div>
  </section>

  <!-- TOC -->
  <section class="py-8 md:py-10 bg-[var(--color-bg)] border-b border-[var(--color-border)]">
    <div class="container-x">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-accent)] mb-4">Im Überblick</h2>
      <ul class="flex flex-wrap gap-2">
        {services.map((s) => (
          <li>
            <a href={`#${s.slug}`} class="trust-badge hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-colors">
              {s.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Service-Details -->
  <section class="py-14 md:py-20 bg-[var(--color-bg)]">
    <div class="container-x">
      <div class="space-y-8 md:space-y-12">
        {services.map((s, idx) => (
          <article
            id={s.slug}
            class="scroll-mt-24 grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10 bg-[var(--color-bg-alt)] rounded-3xl p-7 md:p-10 border border-[var(--color-border)]"
          >
            <div class="md:col-span-3 lg:col-span-2 flex md:flex-col items-center md:items-start gap-4">
              <div class="w-14 h-14 md:w-16 md:h-16 rounded-2xl bg-white flex items-center justify-center flex-shrink-0">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#F39239" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={iconPath[s.icon] ?? iconPath.wrench} />
                </svg>
              </div>
              <div class="text-3xl md:text-5xl font-bold text-[var(--color-accent)] opacity-30 font-num leading-none">
                0{idx + 1}
              </div>
            </div>

            <div class="md:col-span-9 lg:col-span-10">
              <h2 class="text-2xl md:text-3xl font-bold mb-3">{s.title}</h2>
              <p class="text-lg text-[var(--color-text-muted)] leading-relaxed mb-5">
                {s.description}
              </p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2.5 mb-6">
                {s.bullets.map((b) => (
                  <li class="flex items-start gap-2.5 text-[var(--color-text)]">
                    <svg class="mt-1 flex-shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#F39239" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M5 12l5 5 9-11"/>
                    </svg>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
              <div class="flex flex-wrap gap-3">
                <a href={business.phoneHref} class="btn btn-accent font-num">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
                  </svg>
                  Termin anfragen: {business.phoneDisplay}
                </a>
                <a href="/kontakt/" class="btn btn-outline">
                  Per Formular anfragen
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Hinweis: weitere Leistungen -->
  <section class="py-12 md:py-16 bg-[var(--color-bg)]">
    <div class="container-x">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Etwas nicht dabei?</h2>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed mb-6">
          Wir kümmern uns um nahezu alle Reparaturen und Wartungen rund ums Auto - auch um Auspuff, Kupplung, Getriebe oder größere Karosseriearbeiten. Rufen Sie uns einfach an, wir sagen Ihnen ehrlich, ob wir helfen können.
        </p>
        <a href={business.phoneHref} class="btn btn-accent font-num">
          {business.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <CtaSection />
</Layout>
