---
import { business } from '../data/business';

// Pexels-Stockfoto: Werkstatt-Innenansicht mit Auto auf Hebebühne (kostenfrei kommerziell).
const aboutImg = 'https://images.pexels.com/photos/4489734/pexels-photo-4489734.jpeg?auto=compress&cs=tinysrgb&w=1200';
const aboutImgAlt = 'Auto auf der Hebebühne in der Kfz-Werkstatt';

const checks = [
  `Inhabergeführt von ${business.owner}`,
  'Fußläufig zur U-Bahn (Moosach / Neuhausen)',
  'Faire Festpreise - vorab abgestimmt',
  'Persönliche Beratung statt Standardabwicklung',
  'Reparaturen oft in Rekordzeit',
];
---

<section id="ueber-uns" class="py-16 md:py-28 bg-[var(--color-bg-alt)]">
  <div class="container-x">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div>
        <span class="text-sm font-semibold text-[var(--color-accent)] uppercase tracking-wider">Über uns</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-3 mb-5 leading-tight">
          Ihr Auto in guten Händen.
        </h2>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed mb-5">
          Kfz Service Beyer ist eine kleine, inhabergeführte Werkstatt in München.
          Sie finden uns in der Waisenhausstraße 44 - direkt am Übergang zwischen Moosach und Neuhausen, fußläufig zur U-Bahn.
        </p>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed mb-8">
          {business.owner} führt den Betrieb persönlich. Das heißt für Sie: Sie sprechen mit dem, der das Auto auch tatsächlich repariert. Wir nehmen uns Zeit zu erklären, was nötig ist - und was nicht.
        </p>

        <ul class="space-y-3 mb-8">
          {checks.map((c) => (
            <li class="flex items-start gap-3">
              <svg class="mt-1 flex-shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#F39239" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12l5 5 9-11"/>
              </svg>
              <span class="text-[var(--color-text)] font-medium">{c}</span>
            </li>
          ))}
        </ul>

        <a href="/ueber-uns/" class="btn btn-outline">
          Mehr über uns erfahren
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="relative">
        <!-- Werkstatt-Foto -->
        <div class="relative rounded-3xl overflow-hidden border border-[var(--color-border)] shadow-xl shadow-black/10 aspect-[4/5]">
          <img
            src={aboutImg}
            alt={aboutImgAlt}
            class="w-full h-full object-cover"
            loading="lazy"
            width="1200"
            height="1500"
          />
          <!-- Anthrazit-Verlauf unten für Text-Lesbarkeit -->
          <div class="absolute inset-x-0 bottom-0 h-2/5 bg-gradient-to-t from-[var(--color-dark)]/90 via-[var(--color-dark)]/40 to-transparent"></div>

          <!-- Quote-Overlay unten -->
          <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 text-white">
            <svg class="text-[var(--color-accent)] mb-3" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M9 7c-3 0-5 2.5-5 6v6h6v-6H6c0-2 1-3 3-3V7zm10 0c-3 0-5 2.5-5 6v6h6v-6h-4c0-2 1-3 3-3V7z"/>
            </svg>
            <blockquote class="text-lg md:text-xl font-semibold leading-snug mb-2">
              „Sie halten Wort - keine bösen Überraschungen."
            </blockquote>
            <div class="text-xs text-white/75">Google-Rezension · ★★★★★</div>
          </div>
        </div>

        <!-- Floating Stats-Card unten links -->
        <div class="hidden md:flex absolute -left-5 -bottom-5 bg-white rounded-2xl shadow-xl border border-[var(--color-border)] px-5 py-4 items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-[var(--color-accent-soft)] flex items-center justify-center flex-shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="#F39239" aria-hidden="true">
              <path d="M12 2l3 7h7l-5.5 4 2 7-6.5-4.5L5.5 20l2-7L2 9h7z"/>
            </svg>
          </div>
          <div>
            <div class="text-2xl font-bold leading-none font-num">{business.google.stars}<span class="text-base text-[var(--color-accent)]"> / 5</span></div>
            <div class="text-xs text-[var(--color-text-muted)] mt-1">{business.google.count} Bewertungen</div>
          </div>
        </div>

        <!-- Floating Address-Tag oben rechts -->
        <div class="hidden md:flex absolute -right-3 -top-3 bg-[var(--color-accent)] text-white rounded-xl shadow-xl px-4 py-3 items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div class="text-sm font-semibold leading-tight">Waisenhausstr. 44</div>
        </div>
      </div>
    </div>
  </div>
</section>
