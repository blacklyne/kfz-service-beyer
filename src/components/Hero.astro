---
import { business } from '../data/business';

// Pexels-Stockfoto (Pexels-Lizenz: kostenfrei kommerziell nutzbar, keine Attribution-Pflicht).
// Falls eigenes Werkstatt-Foto vorhanden: hier durch /images/hero.jpg ersetzen
// und unter public/images/hero.jpg ablegen.
const heroImg = 'https://images.pexels.com/photos/3807277/pexels-photo-3807277.jpeg?auto=compress&cs=tinysrgb&w=1400&fit=crop';
const heroImgAlt = 'Mechaniker bei der Arbeit an einem Motor in der Kfz-Werkstatt';
---

<section class="relative -mt-16 md:-mt-20 pt-24 md:pt-28 pb-16 md:pb-24 bg-[var(--color-bg)] overflow-hidden">
  <!-- Dezente Decor-Shape: Logo-Trapez als Hintergrund-Akzent -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <svg class="absolute -right-32 -top-24 opacity-[0.05] w-[640px] h-auto" viewBox="0 0 600 400" fill="none">
      <polygon points="20,30 380,30 320,150 20,150" fill="#F39239"/>
      <polygon points="20,180 380,180 320,300 20,300" fill="#F39239"/>
    </svg>
  </div>

  <div class="container-x relative">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-center">
      <!-- Text-Spalte -->
      <div class="lg:col-span-7">
        <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-[var(--color-accent-soft)] text-[var(--color-accent-hover)] text-sm font-semibold mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></span>
          KFZ-Werkstatt · München · Seit Jahren
        </div>

        <h1 class="text-[40px] sm:text-5xl md:text-6xl lg:text-[64px] leading-[1.05] mb-6 text-[var(--color-text)]">
          Ihre Werkstatt im<br />
          <span class="text-[var(--color-accent)]">Herzen Münchens.</span>
        </h1>

        <p class="text-lg md:text-xl text-[var(--color-text-muted)] max-w-xl mb-8 leading-relaxed">
          Inspektion, Reparatur und TÜV — ehrlich, fair und persönlich. Bei uns bekommen Sie keine bösen Überraschungen, sondern transparente Beratung und Reparaturen in Rekordzeit.
        </p>

        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a
            href={business.phoneHref}
            class="btn btn-accent text-base md:text-lg px-6 py-4 font-num"
            aria-label={`Jetzt anrufen: ${business.phoneDisplay}`}
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z" />
            </svg>
            {business.phoneDisplay}
          </a>
          <a href="/kontakt/" class="btn btn-ghost text-base md:text-lg px-6 py-4">
            Termin anfragen
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Trust-Bar -->
        <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
          <div class="flex items-center gap-2.5">
            <div class="text-[var(--color-accent)] text-lg leading-none" aria-hidden="true">★★★★★</div>
            <div class="text-sm">
              <span class="font-semibold text-[var(--color-text)] font-num">{business.google.stars}</span>
              <span class="text-[var(--color-text-muted)]"> · {business.google.count} Google-Bewertungen</span>
            </div>
          </div>
          <div class="hidden sm:block w-px h-5 bg-[var(--color-border)]"></div>
          <div class="flex items-center gap-2 text-sm text-[var(--color-text-muted)]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-accent)]"><path d="M20 7L9 18l-5-5"/></svg>
            Inhabergeführter Familienbetrieb
          </div>
        </div>
      </div>

      <!-- Bild-Spalte -->
      <div class="lg:col-span-5">
        <div class="relative">
          <!-- Bild-Frame mit Anthrazit-Border -->
          <div class="relative rounded-3xl overflow-hidden border border-[var(--color-border)] shadow-2xl shadow-black/10 aspect-[4/5] lg:aspect-[3/4] bg-[var(--color-dark)]">
            <img
              src={heroImg}
              alt={heroImgAlt}
              class="w-full h-full object-cover"
              loading="eager"
              fetchpriority="high"
              width="1400"
              height="1050"
            />
            <!-- Subtiler Anthrazit-Verlauf unten für Lesbarkeit der Badge -->
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-[var(--color-dark)]/85 to-transparent"></div>

            <!-- Kennzahl-Overlay -->
            <div class="absolute bottom-5 left-5 right-5 text-white">
              <div class="text-xs uppercase tracking-wider text-[var(--color-accent)] font-semibold mb-1">Heute geöffnet</div>
              <div class="text-xl font-bold font-num">07:00 – 17:00 Uhr</div>
              <div class="text-sm text-white/85 mt-0.5">{business.street} · {business.zip} {business.city}</div>
            </div>
          </div>

          <!-- Floating Rating-Card -->
          <div class="hidden md:flex absolute -left-6 -bottom-6 bg-white rounded-2xl shadow-xl border border-[var(--color-border)] px-5 py-4 items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-[var(--color-accent-soft)] flex items-center justify-center flex-shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="#F39239" aria-hidden="true">
                <path d="M12 2l3 7h7l-5.5 4 2 7-6.5-4.5L5.5 20l2-7L2 9h7z"/>
              </svg>
            </div>
            <div>
              <div class="text-2xl font-bold leading-none font-num">{business.google.stars}<span class="text-base text-[var(--color-accent)]"> / 5</span></div>
              <div class="text-xs text-[var(--color-text-muted)] mt-1">{business.google.count} Google-Bewertungen</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
