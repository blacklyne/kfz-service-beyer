---
import { business } from '../data/business';

// Pexels-Stockfoto (Pexels-Lizenz: kostenfrei kommerziell nutzbar, keine Attribution-Pflicht).
// Falls eigenes Werkstatt-Foto vorhanden: hier durch /images/hero.jpg ersetzen
// und unter public/images/hero.jpg ablegen.
const heroImg = 'https://images.pexels.com/photos/3807277/pexels-photo-3807277.jpeg?auto=compress&cs=tinysrgb&w=1920&fit=crop';
const heroImgAlt = 'Mechaniker bei der Arbeit an einem Motor in der Kfz-Werkstatt';
---

<section class="relative -mt-16 md:-mt-20 min-h-[680px] md:min-h-[760px] flex items-center text-white overflow-hidden">
  <!-- Background-Bild -->
  <img
    src={heroImg}
    alt={heroImgAlt}
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
    width="1920"
    height="1280"
  />

  <!-- Dark Overlay für Text-Lesbarkeit -->
  <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-dark)]/85 via-[var(--color-dark)]/65 to-[var(--color-dark)]/30"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-dark)]/40 to-transparent"></div>

  <div class="container-x relative z-10 pt-28 md:pt-36 pb-16 md:pb-24 w-full">
    <div class="max-w-3xl">
      <!-- Heute-geöffnet-Pill -->
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-sm font-semibold text-white mb-6">
        <span class="relative flex w-2 h-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-60"></span>
          <span class="relative inline-flex w-2 h-2 rounded-full bg-green-400"></span>
        </span>
        KFZ-Werkstatt München · Heute geöffnet
      </div>

      <h1 class="text-[40px] sm:text-5xl md:text-6xl lg:text-[72px] leading-[1.04] mb-6 text-white">
        Ihre Werkstatt im<br />
        <span class="text-[var(--color-accent)]">Herzen Münchens.</span>
      </h1>

      <p class="text-lg md:text-xl text-white/85 max-w-2xl mb-8 leading-relaxed">
        Inspektion, Reparatur und TÜV - ehrlich, fair und persönlich. Bei uns bekommen Sie keine bösen Überraschungen, sondern transparente Beratung und Reparaturen in Rekordzeit.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 mb-10">
        <a
          href={business.phoneHref}
          class="btn btn-accent text-base md:text-lg px-6 py-4 font-num"
          aria-label={`Jetzt anrufen: ${business.phoneDisplay}`}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z" />
          </svg>
          {business.phoneDisplay}
        </a>
        <a href="/kontakt/" class="btn btn-ghost-light text-base md:text-lg px-6 py-4">
          Termin anfragen
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Trust-Bar -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-3">
        <div class="flex items-center gap-2.5">
          <div class="text-[var(--color-accent)] text-lg leading-none" aria-hidden="true">★★★★★</div>
          <div class="text-sm text-white/90">
            <span class="font-semibold font-num">{business.google.stars}</span>
            · {business.google.count} Google-Bewertungen
          </div>
        </div>
        <span class="hidden sm:block w-px h-5 bg-white/25"></span>
        <div class="flex items-center gap-2 text-sm text-white/85">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-[var(--color-accent)]"><path d="M20 7L9 18l-5-5"/></svg>
          Inhabergeführter Familienbetrieb
        </div>
      </div>
    </div>
  </div>
</section>
