---
import { business, reviews } from '../data/business';
// Auf der Startseite zeigen wir 3 Reviews
const featured = reviews.slice(0, 3);
---

<section id="bewertungen" class="py-16 md:py-28 bg-[var(--color-bg-alt)]">
  <div class="container-x">
    <div class="max-w-2xl mb-10 md:mb-14">
      <span class="text-sm font-semibold text-[var(--color-accent)] uppercase tracking-wider">Was Kunden sagen</span>
      <h2 class="text-3xl md:text-5xl font-bold mt-3 mb-5 leading-tight">{business.google.stars} Sterne - von Münchnern, die gerne wiederkommen.</h2>
      <div class="flex flex-wrap items-center gap-3 text-[var(--color-text-muted)]">
        <span class="text-2xl text-[var(--color-accent)]" aria-hidden="true">★★★★★</span>
        <span class="text-base">
          <span class="font-semibold text-[var(--color-text)] font-num">{business.google.stars}</span>
          aus {business.google.count} Google-Bewertungen
        </span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6">
      {featured.map((r) => (
        <article class="bg-white rounded-2xl p-7 md:p-8 border border-[var(--color-border)] flex flex-col">
          <div class="text-[var(--color-accent)] text-lg mb-4" aria-label={`${r.stars} von 5 Sternen`}>
            {'★'.repeat(r.stars)}{'☆'.repeat(5 - r.stars)}
          </div>
          <blockquote class="text-[var(--color-text)] text-lg leading-relaxed mb-5 flex-1">
            „{r.text}"
          </blockquote>
          <footer class="flex items-center gap-3 pt-4 border-t border-[var(--color-border)]">
            <div class="w-10 h-10 rounded-full bg-[var(--color-accent-soft)] flex items-center justify-center text-[var(--color-accent)] font-bold">G</div>
            <div>
              <div class="font-semibold text-sm">{r.name}</div>
              <div class="text-xs text-[var(--color-text-muted)]">{r.source}</div>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={business.mapsLink}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline"
      >
        Alle Bewertungen auf Google
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
      </a>
    </div>
  </div>
</section>
