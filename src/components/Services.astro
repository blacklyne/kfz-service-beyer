---
import { services } from '../data/business';

const iconPath: Record<string, string> = {
  wrench: 'M14.7 6.3a1 1 0 010 1.4l-1.4 1.4 3.6 3.6 1.4-1.4a1 1 0 011.4 0l1.7 1.7a1 1 0 010 1.4l-1.7 1.7a4 4 0 01-5.6 0L4.7 6.7a4 4 0 010-5.6L6.4-.6a1 1 0 011.4 0l1.7 1.7a1 1 0 010 1.4L8.1 4l3.6 3.6 1.4-1.4a1 1 0 011.4 0l.2.1zM3 18l4-4M7 22l4-4',
  car: 'M5 17h14M5 17v3m14-3v3M3 13l2-6h14l2 6m-18 0v4h18v-4M3 13h18M7 16.5h.01M17 16.5h.01',
  disc: 'M12 12m-9 0a9 9 0 1018 0 9 9 0 10-18 0M12 12m-3.5 0a3.5 3.5 0 107 0 3.5 3.5 0 10-7 0',
  target: 'M12 12m-9 0a9 9 0 1018 0 9 9 0 10-18 0M12 12m-5 0a5 5 0 1010 0 5 5 0 10-10 0M12 12h.01',
  shield: 'M12 3l8 3v6c0 5-3.5 8.5-8 9-4.5-.5-8-4-8-9V6l8-3z M9 12l2 2 4-4',
  droplet: 'M12 3l5.5 8a6.5 6.5 0 11-11 0L12 3z',
  snowflake: 'M12 3v18M5 7l14 10M5 17l14-10M3 12h18M9 5l3-2 3 2M9 19l3 2 3-2',
  cpu: 'M9 3h6v3h3v3h3v6h-3v3h-3v3H9v-3H6v-3H3V9h3V6h3z M9 9h6v6H9z',
  circle: 'M12 12m-9 0a9 9 0 1018 0 9 9 0 10-18 0M12 12m-5 0a5 5 0 1010 0 5 5 0 10-10 0',
};

// Auf der Startseite zeigen wir die ersten 6 Leistungen als Kacheln
const preview = services.slice(0, 6);
---

<section id="leistungen" class="py-16 md:py-28 bg-[var(--color-bg)]">
  <div class="container-x">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10 md:mb-14">
      <div class="max-w-2xl">
        <span class="text-sm font-semibold text-[var(--color-accent)] uppercase tracking-wider">Unsere Leistungen</span>
        <h2 class="text-3xl md:text-5xl font-bold mt-3 mb-4 leading-tight">Alles für Ihr Auto — aus einer Hand.</h2>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
          Vom Ölwechsel bis zur Hauptuntersuchung kümmern wir uns um alles, was Ihr Fahrzeug im Alltag braucht. Ehrlich, transparent — und mit klaren Empfehlungen.
        </p>
      </div>
      <a href="/leistungen/" class="btn btn-outline self-start whitespace-nowrap">
        Alle Leistungen ansehen
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {preview.map((s) => (
        <a
          href={`/leistungen/#${s.slug}`}
          class="group bg-white rounded-2xl p-7 md:p-8 border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:shadow-lg hover:-translate-y-0.5 transition-all"
        >
          <div class="w-12 h-12 rounded-xl bg-[var(--color-accent-soft)] flex items-center justify-center mb-5 group-hover:bg-[var(--color-accent)] transition-colors">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)] group-hover:text-white">
              <path d={iconPath[s.icon] ?? iconPath.wrench} />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">{s.title}</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed text-[15px]">{s.short}</p>
        </a>
      ))}
    </div>
  </div>
</section>
